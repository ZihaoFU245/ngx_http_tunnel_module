ngx_addon_name=ngx_http_tunnel_module

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_tunnel_module
    ngx_module_srcs="$ngx_addon_dir/ngx_http_tunnel_module.c \
                     $ngx_addon_dir/ngx_http_tunnel_module_auth.c \
                     $ngx_addon_dir/ngx_http_tunnel_module_connect.c \
                     $ngx_addon_dir/ngx_http_tunnel_module_padding.c \
                     $ngx_addon_dir/ngx_http_tunnel_module_relay.c \
                     $ngx_addon_dir/ngx_http_tunnel_module_relay_stream.c"

    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_tunnel_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_addon_dir/ngx_http_tunnel_module.c \
                   $ngx_addon_dir/ngx_http_tunnel_module_auth.c \
                   $ngx_addon_dir/ngx_http_tunnel_module_connect.c \
                   $ngx_addon_dir/ngx_http_tunnel_module_padding.c \
                   $ngx_addon_dir/ngx_http_tunnel_module_relay.c \
                   $ngx_addon_dir/ngx_http_tunnel_module_relay_stream.c"
fi
