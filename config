ngx_addon_name=ngx_http_tunnel_module

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_tunnel_module
    ngx_module_srcs="$ngx_addon_dir/src/core.c \
                     $ngx_addon_dir/src/acl.c \
                     $ngx_addon_dir/src/auth.c \
                     $ngx_addon_dir/src/connect.c \
                     $ngx_addon_dir/src/udp.c \
                     $ngx_addon_dir/src/udp_relay.c \
                     $ngx_addon_dir/src/padding.c \
                     $ngx_addon_dir/src/relay.c \
                     $ngx_addon_dir/src/relay_v2.c \
                     $ngx_addon_dir/src/utils.c"

    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_tunnel_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_addon_dir/src/core.c \
                   $ngx_addon_dir/src/auth.c \
                   $ngx_addon_dir/src/acl.c \
                   $ngx_addon_dir/src/connect.c \
                   $ngx_addon_dir/src/udp.c \
                   $ngx_addon_dir/src/udp_relay.c \
                   $ngx_addon_dir/src/padding.c \
                   $ngx_addon_dir/src/relay.c \
                   $ngx_addon_dir/src/relay_v2.c \
                   $ngx_addon_dir/src/utils.c"
fi
