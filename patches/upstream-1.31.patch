From 444a9e0844189f0184d872e1b792360e0680b9fa Mon Sep 17 00:00:00 2001
From: zihaofu245 <172541422+ZihaoFU245@users.noreply.github.com>
Date: Fri, 8 May 2026 22:53:57 +0800
Subject: [PATCH] upstream patch

---
 src/http/ngx_http_upstream.c | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/src/http/ngx_http_upstream.c b/src/http/ngx_http_upstream.c
index bb8964add..74b58f037 100644
--- a/src/http/ngx_http_upstream.c
+++ b/src/http/ngx_http_upstream.c
@@ -2592,6 +2592,10 @@ again:
 
 done:
 
+    if (rc == NGX_DONE) {
+        return;
+    }
+
     if (rc == NGX_HTTP_UPSTREAM_INVALID_HEADER) {
         ngx_http_upstream_next(r, u, NGX_HTTP_UPSTREAM_FT_INVALID_HEADER);
         return;
@@ -3327,6 +3331,11 @@ ngx_http_upstream_send_response(ngx_http_request_t *r, ngx_http_upstream_t *u)
 
 #endif
 
+        if (u->conf->ignore_input) {
+            ngx_http_upstream_finalize_request(r, u, 0);
+            return;
+        }
+
         if (u->input_filter == NULL) {
             u->input_filter_init = ngx_http_upstream_non_buffered_filter_init;
             u->input_filter = ngx_http_upstream_non_buffered_filter;
-- 
